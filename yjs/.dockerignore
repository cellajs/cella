# Ignore everything by default
*

# Include necessary files for build context

# Root config files
!package.json
!pnpm-lock.yaml
!pnpm-workspace.yaml

# Yjs Worker
!yjs/package.json
!yjs/src/
!yjs/tsconfig.json

# Shared package
!shared/

# Ignore tests and dev files
**/*.test.ts
**/*.spec.ts
**/tests/
**/.env*
**/node_modules/
**/.git/
**/dist/
**/*.md
**/.DS_Store
