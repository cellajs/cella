{
  "name": "shared",
  "description": "Shared config, permissions, types, and cross-package utilities",
  "type": "module",
  "scripts": {
    "ts": "cd .. && tsgo -p shared/tsconfig.json --pretty",
    "tsperf": "rm -rf tsconfig.tsbuildinfo && tsgo --noEmit --extendedDiagnostics",
    "test": "vitest run"
  },
  "exports": {
    ".": "./index.ts",
    "./entity-id": "./src/utils/entity-id.ts",
    "./nanoid": "./src/utils/nanoid.ts",
    "./hash-source-id": "./src/utils/hash-source-id.ts",
    "./transloadit-config": "./transloadit-config.ts",
    "./tracing": "./src/tracing/tracing.ts",
    "./otel": "./src/otel.ts",
    "./config-builder": "./src/config-builder/index.ts",
    "./blocknote": "./src/utils/text-from-block.ts",
    "./is-cdn-url": "./src/utils/is-cdn-url.ts",
    "./validate-block-media-urls": "./src/utils/validate-block-media-urls.ts",
    "./ascii": "./src/utils/ascii.ts",
    "./console": "./src/utils/console.ts",
    "./cli-utils/colors": "./src/cli-utils/colors.ts",
    "./cli-utils/display": "./src/cli-utils/display.ts",
    "./worker-lifecycle": "./src/utils/worker-lifecycle.ts",
    "./wait-for-backend": "./src/utils/wait-for-backend.ts",
    "./display-order": "./src/utils/display-order.ts",
    "./pino": "./src/pino.ts"
  },
  "dependencies": {
    "@blocknote/core": "^0.51.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-logs": "^0.218.0",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "nanoid": "^5.1.11",
    "picocolors": "^1.1.1",
    "pino": "^10.3.1",
    "pino-opentelemetry-transport": "^3.0.0",
    "uuidv7": "^1.2.1"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260526.1",
    "strip-json-comments": "^5.0.3",
    "typescript": "^6.0.3"
  }
}
