{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "..",
    "noEmit": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    // Node-only VM agent: no DOM globals (the infra config adds "dom" for the
    // Pulumi program's fetch typing; Node's own types cover fetch here).
    "lib": ["es2024"],
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    "../lib/utils/args.ts",
    "../lib/utils/env-file.ts",
    "../lib/utils/errors.ts",
    "../lib/utils/escape-regexp.ts",
    "../lib/utils/fetch-like.ts",
    "../lib/utils/guards.ts",
    "../lib/utils/is-main.ts",
    "../lib/utils/json.ts",
    "../lib/utils/retry.ts"
  ],
  "exclude": ["src/**/*.test.ts"]
}