{
  "name": "infra",
  "description": "Pulumi IaC for Scaleway infrastructure and Kubernetes workloads",
  "type": "module",
  "scripts": {
    "cli": "tsx cli/infra-cli.ts",
    "setup-ci-key": "tsx tasks/setup-ci-key.ts",
    "test": "vitest run",
    "test:integration": "INTEGRATION=1 vitest run tests/integration",
    "preview": "pulumi preview",
    "up": "pulumi up",
    "destroy": "pulumi destroy",
    "ensure-state-bucket": "tsx tasks/ensure-state-bucket.ts",
    "print-deploy-env": "tsx tasks/print-deploy-env.ts",
    "print-frontend-build-env": "tsx tasks/print-frontend-build-env.ts",
    "install-pulumi-providers": "tsx tasks/install-pulumi-providers.ts",
    "sync-rollout-config": "tsx tasks/sync-rollout-config.ts",
    "deploy-rollout": "tsx tasks/deploy-rollout.ts",
    "stack-lock": "tsx tasks/stack-lock.ts",
    "wait-for-version": "tsx tasks/wait-for-version.ts",
    "wait-for-images": "tsx tasks/wait-for-images.ts",
    "cutover": "tsx tasks/cutover.ts",
    "deploy-service": "tsx tasks/deploy-service.ts",
    "assert-vm-grants": "tsx tasks/assert-vm-grants.ts",
    "assert-secrets-deliverable": "tsx tasks/assert-secrets-deliverable.ts",
    "fetch-boot-diag": "tsx tasks/fetch-boot-diag.ts",
    "diag": "tsx tasks/diag.ts",
    "agent:build": "rm -rf agent/dist && tsc --noEmit -p agent/tsconfig.json && tsup agent/src/entry.ts --format cjs --platform node --target node24 --out-dir agent/dist",
    "agent:image": "pnpm run agent:build && docker build -t ${AGENT_IMAGE:-cella-boot-agent:dev} agent",
    "compose:generate": "tsx compose/synth.ts",
    "compose:check": "tsx compose/synth.ts --check",
    "smoke": "tsx tasks/smoke.ts",
    "ts": "cd .. && tsgo -p infra/tsconfig.json --pretty",
    "tsperf": "rm -rf tsconfig.tsbuildinfo && tsgo --noEmit --extendedDiagnostics"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "catalog:",
    "@inquirer/core": "^11.2.1",
    "@inquirer/prompts": "^8.5.1",
    "@pulumi/pulumi": "^3.247.0",
    "@pulumi/random": "^4.21.0",
    "@pulumiverse/scaleway": "^1.50.1",
    "shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
