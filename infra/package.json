{
  "name": "infra",
  "description": "Pulumi IaC for Scaleway infrastructure and Kubernetes workloads",
  "type": "module",
  "scripts": {
    "bootstrap": "tsx tasks/bootstrap.ts",
    "setup-ci-key": "tsx tasks/setup-ci-key.ts",
    "test": "vitest run",
    "test:integration": "INTEGRATION=1 vitest run tests/integration",
    "preview": "pulumi preview",
    "up": "pulumi up",
    "destroy": "pulumi destroy",
    "ensure-state-bucket": "tsx tasks/ensure-state-bucket.ts",
    "init-stack-secrets": "tsx tasks/init-stack-secrets.ts",
    "print-deploy-env": "tsx tasks/print-deploy-env.ts",
    "ts": "cd .. && tsgo -p infra/tsconfig.json --pretty",
    "tsperf": "rm -rf dist && rm -rf tsconfig.tsbuildinfo && tsgo --extendedDiagnostics"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1044.0",
    "@inquirer/prompts": "^8.4.2",
    "@pulumi/pulumi": "^3.236.0",
    "@pulumi/random": "^4.19.2",
    "@pulumiverse/scaleway": "^1.48.0",
    "shared": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
