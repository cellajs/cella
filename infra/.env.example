# Standalone deploy environment variables
#
# Copy this file to .env and fill in the values.
# Used by infra/compose.yml for standalone Docker Compose deployments.
# See infra/STANDALONE.md. Pulumi-managed deploys do not use this file.

# Container registry (e.g. rg.nl-ams.scw.cloud/<slug>)
REGISTRY=
BACKEND_TAG=latest
CDC_TAG=latest
YJS_TAG=latest
AI_TAG=latest

# App mode
APP_MODE=production

# URLs
FRONTEND_URL=https://www.cella.dev
BACKEND_URL=https://api.cella.dev
AI_API_URL=https://ai.cella.dev
# CDC WebSocket URL to backend internal endpoint
API_WS_URL=wss://api.cella.dev/internal/cdc

# Caddy host names (consumed by infra/Caddyfile)
APEX_HOST=cella.dev
APP_HOST=www.cella.dev
BACKEND_HOST=api.cella.dev
YJS_HOST=yjs.cella.dev
AI_HOST=ai.cella.dev

# Database connection strings
DATABASE_URL=
DATABASE_ADMIN_URL=
DATABASE_CDC_URL=

# Application secrets
COOKIE_SECRET=
UNSUBSCRIBE_SECRET=
CDC_SECRET=
YJS_SECRET=
PII_HASH_SECRET=
BREVO_API_KEY=
ADMIN_EMAIL=
