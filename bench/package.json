{
  "name": "bench",
  "version": "1.0.0",
  "private": true,
  "description": "Artillery load-testing scenarios and tooling",
  "scripts": {
    "bench": "tsx src/bench-cli.ts",
    "db:seed": "tsx src/data-setup.ts",
    "db:teardown": "tsx src/data-setup.ts --teardown",
    "db:up": "docker compose -f ../backend/compose.yaml up db -d && echo 'Waiting for Postgres...' && until pg_isready -h 0.0.0.0 -p 5433 -U postgres -q 2>/dev/null; do sleep 0.5; done && echo 'Postgres ready.' && pnpm db:seed"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "nanoid": "^5.1.11",
    "ora": "^9.4.0",
    "pg": "^8.21.0",
    "shared": "workspace:*",
    "uuidv7": "^1.2.1"
  },
  "devDependencies": {
    "@types/node": "24.10.13",
    "@types/pg": "^8.20.0",
    "artillery": "^2.0.31",
    "artillery-plugin-ensure": "^1.25.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
