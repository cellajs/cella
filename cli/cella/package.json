{
  "name": "@cellajs/cli",
  "version": "0.0.1",
  "private": false,
  "license": "MIT",
  "description": "CLI for syncing & managing apps with upstream Cella",
  "repository": {
    "type": "git",
    "url": "https://github.com/cellajs/cella",
    "directory": "cli/cella"
  },
  "homepage": "https://cellajs.com",
  "author": "CellaJS <info@cellajs.com>",
  "engines": {
    "node": "24.x"
  },
  "type": "module",
  "main": "index.ts",
  "bin": {
    "cli": "index.ts"
  },
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "cella": "tsx index.ts",
    "validate": "tsx index.ts --service analyze",
    "check": "pnpm ts && pnpm biome check --write .",
    "ts": "tsgo --pretty",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@inquirer/core": "^11.2.1",
    "@inquirer/prompts": "^8.5.2",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@types/node": "24.10.13",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4"
  }
}
