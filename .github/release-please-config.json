{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "separate-pull-requests": true,
  "pull-request-header": "Automated release PR. Review the changelog below, then merge to cut the release.",
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "include-v-in-tag": false,
  "changelog-sections": [
    { "type": "feat", "section": "🎉 New features" },
    { "type": "fix", "section": "🐞 Bug fixes" },
    { "type": "perf", "section": "🔧 Small improvements" },
    { "type": "refactor", "section": "🔧 Small improvements" },
    { "type": "revert", "section": "⏪ Reverts" },
    { "type": "docs", "section": "📖 Documentation" },
    { "type": "build", "section": "🏗️ Build & deps" },
    { "type": "ci", "section": "🏗️ Build & deps" },
    { "type": "chore", "section": "🧹 Chores" },
    { "type": "style", "section": "🎨 Styles" },
    { "type": "test", "section": "🧪 Tests" }
  ],
  "packages": {
    ".": {
      "release-type": "node",
      "include-component-in-tag": false,
      "changelog-path": "cella/CHANGELOG.md"
    }
  }
}
