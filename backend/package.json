{
  "name": "backend",
  "version": "0.0.2",
  "description": "Hono API server with postgres, auth, CRUD, and real-time sync",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "start": "cross-env NODE_ENV=production tsx dist/main.js",
    "dev": "cross-env NODE_ENV=development tsx --watch-path=src src/main.ts",
    "tunnel": "cross-env NODE_ENV=tunnel tsx --watch-path=src src/main.ts",
    "ts": "cd .. && tsgo -p backend/tsconfig.json --pretty",
    "tsperf": "rm -rf dist && rm -rf tsconfig.tsbuildinfo && tsgo --extendedDiagnostics",
    "build": "cross-env NODE_ENV=production tsup",
    "build:dev": "tsup",
    "build:staging": "cross-env NODE_ENV=staging tsup",
    "docker:up": "docker compose up",
    "docker:down": "docker compose down",
    "stop": "pnpm docker:down",
    "seed": "tsx scripts/seeds.ts",
    "migrate": "tsx scripts/migrate.ts",
    "db:reset": "tsx scripts/reset-db.ts",
    "db:clear": "tsx scripts/clear-db.ts",
    "generate:pg": "drizzle-kit generate --config drizzle.config.ts",
    "generate": "tsx scripts/generate.ts",
    "generate:openapi": "tsx scripts/generate-openapi.ts",
    "push": "drizzle-kit push",
    "studio": "drizzle-kit studio --config drizzle.config.ts",
    "test": "cross-env TEST_MODE=core vitest run",
    "manual-migration": "tsx scripts/manual-migration.ts",
    "test:full": "cross-env TEST_MODE=full vitest run",
    "seed:production": "node dist/seeds-bundle.js",
    "seed:k8s": "node dist/seeds-bundle.js",
    "geoip:download": "tsx scripts/download-geoip.ts",
    "s3:cors": "tsx scripts/set-bucket-cors.ts"
  },
  "dependencies": {
    "@ag-ui/core": "^0.0.55",
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@aws-sdk/client-s3": "^3.1063.0",
    "@aws-sdk/s3-request-presigner": "^3.1063.0",
    "@blocknote/core": "^0.51.4",
    "@blocknote/server-util": "^0.51.4",
    "@dotenv-run/core": "^1.3.8",
    "@getbrevo/brevo": "^5.0.4",
    "@hono/node-server": "^2.0.4",
    "@hono/otel": "^1.1.1",
    "@hono/zod-openapi": "^1.3.0",
    "@isaacs/ttlcache": "^2.1.5",
    "@napi-rs/canvas": "^1.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-logs": "^0.218.0",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "@oslojs/otp": "^1.1.0",
    "@oslojs/webauthn": "^1.0.0",
    "@t3-oss/env-core": "^0.13.11",
    "@tanstack/ai": "^0.28.0",
    "arctic": "^3.7.0",
    "drizzle-orm": "1.0.0-rc.3",
    "enforce-unique": "^1.3.0",
    "hono": "^4.12.23",
    "html-to-text": "^10.0.0",
    "i18next": "^26.3.1",
    "isbot": "^5.1.41",
    "locales": "workspace:*",
    "lru-cache": "^11.5.1",
    "maxmind": "^5.0.0",
    "nanoid": "^5.1.11",
    "openai": "^6.42.0",
    "ora": "^9.4.0",
    "pg": "^8.21.0",
    "pg-boss": "^12.18.2",
    "pg-logical-replication": "^2.5.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-opentelemetry-transport": "^3.0.0",
    "rate-limiter-flexible": "^11.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.7",
    "rehype": "^13.0.2",
    "rehype-stringify": "^10.0.1",
    "sanitize-html": "^2.17.3",
    "sdk": "workspace:*",
    "shared": "workspace:*",
    "slugify": "^1.6.9",
    "transloadit": "4.10.6",
    "ua-parser-js": "^2.0.10",
    "uuidv7": "^1.2.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commander-js/extra-typings": "^15.0.0",
    "@faker-js/faker": "^10.4.0",
    "@hono/vite-dev-server": "^0.26.0",
    "@ngrok/ngrok": "^1.7.0",
    "@types/hast": "^3.0.4",
    "@types/html-to-text": "^9.0.4",
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.15",
    "@types/sanitize-html": "^2.16.1",
    "@types/ua-parser-js": "^0.7.39",
    "@types/ws": "^8.18.1",
    "@typescript/native-preview": "catalog:",
    "commander": "^15.0.0",
    "cross-env": "catalog:",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^1.0.0-rc.4-5d5b77c",
    "picocolors": "^1.1.1",
    "pino-pretty": "^13.1.3",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "^8.0.16",
    "vitest": "catalog:"
  },
  "exports": {
    "types": "./dist/src/index.d.ts"
  },
  "types": "./dist/src/index.d.ts"
}
