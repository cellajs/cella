#*******************************************************************************
# REQUIRED ENVIRONMENT VARIABLES
#*******************************************************************************

# Docker compose.yaml variables
PROJECT_SLUG=cella
DB_PORT=5432
DB_TEST_PORT=5434

# Node environment
NODE_ENV=development

# Database connections
# DATABASE_URL uses runtime_role (subject to RLS)
# DATABASE_ADMIN_URL uses superuser for migrations, system admin access, and auto-creating roles
# DATABASE_CDC_URL uses admin_role — CDC needs REPLICATION + BYPASSRLS (for seq stamping under FORCE RLS).
# This mirrors production (Scaleway only grants REPLICATION to isAdmin users).
# Roles (runtime_role, admin_role) are auto-created on startup using passwords from these URLs.
DATABASE_URL=postgres://runtime_role:dev_password@0.0.0.0:5432/postgres
DATABASE_ADMIN_URL=postgres://postgres:postgres@0.0.0.0:5432/postgres
DATABASE_CDC_URL=postgres://admin_role:dev_password@0.0.0.0:5432/postgres

# Optional: separate password for admin_role (defaults to runtime_role password if not set)
# DATABASE_ADMIN_ROLE_PASSWORD=

# Secret for email unsubscribe token
UNSUBSCRIBE_SECRET=some_secret_token

# Secret for cookies
COOKIE_SECRET=cookie_secret

# CDC Worker authentication (optional in quick mode)
CDC_SECRET=some_secret_for_cdc_worker

# Yjs relay authentication
YJS_SECRET=some_secret_for_yjs_relay

# Pepper for one-way hashing of PII used as lookup keys (rate limiter, audit logs, etc.)
# Rotate to invalidate all derived keys. Must be at least 16 characters.
PII_HASH_SECRET=some_secret_pepper_for_pii_hashing

# System admin IP allowlist: 'none' to disable, '*' for any IP, or comma-separated IPv4 addresses
SYSTEM_ADMIN_IP_ALLOWLIST=none

# Admin email for initial admin user seeding
ADMIN_EMAIL=admin-test@cellajs.com

# Brevo transactional email
# Create an API key at https://app.brevo.com/settings/keys/api
BREVO_API_KEY=
SEND_ALL_TO_EMAIL=

# Scaleway project / organization ID (Required to deploy using infra CLI)
SCW_PROJECT_ID=
SCW_ORGANIZATION_ID=

#*******************************************************************************
# OPTIONAL ENVIRONMENT VARIABLES
#*******************************************************************************

# Debug mode 
DEBUG=false

# Pino
PINO_LOG_LEVEL=info

# Backend port
PORT=4000

# Public URL of the development tunnel
TUNNEL_URL=
TUNNEL_AUTH_TOKEN=

# AI
SCW_AI_API_KEY=

# Maple.dev observability
MAPLE_API_KEY=

# OAuth strategies
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Upload credentials
# Create a Transloadit account at https://transloadit.com/accounts/signup/
TRANSLOADIT_KEY=your_transloadit_key
TRANSLOADIT_SECRET=your_transloadit_secret

# S3 on Scaleway (for file uploads and signed URLs)
S3_ACCESS_KEY_ID=
S3_ACCESS_KEY_SECRET=

# Element
ELEMENT_ROOM_ID=
ELEMENT_BOT_ACCESS_TOKEN=

# GeoIP databases (DB-IP Lite, MMDB format). Download via: pnpm --filter backend geoip:download
# Files are not committed; the Dockerfile downloads them at build time.
# GEOIP_COUNTRY_DB_PATH=./geoip/dbip-country-lite.mmdb
# GEOIP_ASN_DB_PATH=./geoip/dbip-asn-lite.mmdb
