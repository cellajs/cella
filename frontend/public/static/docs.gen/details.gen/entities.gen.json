                          "required": false,
                          "additionalProperties": { "type": "integer", "required": false }
                        }
                      }
                    }
                  },
                  "propagation": {
                    "type": "array",
                    "required": false,
                    "itemType": "object",
                    "items": {
                      "type": "object",
                      "properties": {
                        "sourceType": { "type": "string", "required": true, "description": "Entity type that triggered the propagation (e.g. label)" },
                        "targetType": { "type": "string", "required": true, "description": "Entity type whose cache should be invalidated (e.g. task)" },
                        "field": { "type": "string", "required": true, "description": "Field on the target entity that references the source (e.g. labels)" },
                        "update": {
                          "type": "array",
                          "required": true,
                          "description": "Target entity IDs that need cache refresh",
                          "itemType": "string"
                        },
                        "remove": {
                          "type": "array",
                          "required": true,
                          "description": "Target entity IDs that need the source reference removed",
                          "itemType": "string"
                        }
                      }
                    }
                  }
                }
              }
            },
            "cursor": {
              "type": ["string", "null"],
              "required": true,
              "description": "Last activity ID (use as offset for next request)"
