{
  "name": "frontend",
  "version": "0.0.1",
  "description": "React SPA with tanstack router/query & vite",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development vite --mode development",
    "dev:all": "pnpm concurrently --names \"VITE,STORY\" --prefix name \"pnpm dev\" \"pnpm storybook\"",
    "dev:run": "cross-env NODE_ENV=development vite --mode development",
    "tunnel": "tsx ../shared/scripts/wait-backend.ts && cross-env NODE_ENV=tunnel vite --mode tunnel",
    "start": "cross-env NODE_ENV=production pnpm preview",
    "test": "vitest run",
    "ts": "cd .. && tsgo -p frontend/tsconfig.json --pretty",
    "tsperf": "rm -rf tsconfig.tsbuildinfo && cross-env NODE_ENV=development tsgo --noEmit --extendedDiagnostics",
    "build": "cross-env NODE_ENV=production vite build",
    "build:dev": "cross-env NODE_ENV=development vite build --mode development",
    "build:staging": "cross-env NODE_ENV=staging vite build --mode staging",
    "preview": "vite preview",
    "preview:dev": "cross-env NODE_ENV=development vite preview",
    "offline": "cross-env NODE_ENV=development vite build --mode development && cross-env NODE_ENV=development vite preview",
    "stop": "tsx vite/stop-vite.ts",
    "generate:sdk": "pnpm --filter sdk generate:sdk",
    "storybook": "tsx .storybook/start-storybook.ts"
  },
