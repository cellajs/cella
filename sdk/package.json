{
  "name": "sdk",
  "version": "0.0.1",
  "description": "Auto-generated TypeScript SDK from the backend OpenAPI specification",
  "type": "module",
  "scripts": {
    "dev": "node --watch --import ../shared/scripts/register.mjs src/generate-sdk.ts --watch",
    "watch": "node --watch --import ../shared/scripts/register.mjs src/generate-sdk.ts --watch",
    "ts": "cd .. && tsgo -p sdk/tsconfig.json --pretty",
    "tsperf": "rm -rf tsconfig.tsbuildinfo && tsgo --noEmit --extendedDiagnostics",
    "generate:sdk": "node --import ../shared/scripts/register.mjs src/generate-sdk.ts"
  },
  "exports": {
    ".": "./gen/index.ts",
    "./client": "./gen/client/index.ts",
    "./*": "./gen/*.ts"
  },
  "dependencies": {
    "shared": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "catalog:",
    "@hey-api/spec-types": "^0.2.0",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "chokidar": "^5.0.0",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
