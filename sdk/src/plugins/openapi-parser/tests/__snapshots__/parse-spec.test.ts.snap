      {
        "description": "A content page for documentation purposes.",
        "example": {
          "createdAt": "2024-08-06T10:28:33.226Z",
          "createdBy": "060492d8-cc92-433b-a99e-b40e8d5b42dc",
          "description": "[{"id":"wv1pvo6ikw8yaifq40mapyzk","type":"heading","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left","level":2},"content":[{"type":"text","text":"Pecco vulticulus cunctatio dolorum.","styles":{}}],"children":[]},{"id":"xwx21e333ngqujcbpukfple6","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Tremo molestias charisma clam ipsa suscipit solvo atrox tendo compello. Tonsor ullus damnatio. Cupressus depono sto benigne delego decumbo adaugeo.","styles":{}}],"children":[]},{"id":"h3tnk9zpovjd1ic979l5apjd","type":"heading","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left","level":3},"content":[{"type":"text","text":"AI-driven optimal concept","styles":{}}],"children":[]},{"id":"fixisx6z8hucvnngw4r6gjfz","type":"bulletListItem","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Temperantia demonstro chirographum rerum cui temeritas atrocitas creber sordeo.","styles":{}}],"children":[]},{"id":"tcsht8b45feprfkhrd8bblxz","type":"bulletListItem","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Animadverto maxime theatrum esse amo statua adfectus.","styles":{}}],"children":[]},{"id":"zubypddo8vfjx4d5px26kw7k","type":"bulletListItem","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Conitor accusantium virgo sublime rem termes agnitio talis catena pectus.","styles":{}}],"children":[]},{"id":"q8bqakccdhvdb8s40m4i46ag","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Adiuvo brevis conturbo alveus ver ait deserunt decet.","styles":{}}],"children":[]},{"id":"l7dazo02dcpq1pli45kzw5po","type":"numberedListItem","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Vestrum solus cohors trucido ad vorax voluptatum.","styles":{}}],"children":[]},{"id":"4mygjrjwhp4cvi7x941wz85b","type":"numberedListItem","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Conor ullam conculco turpis cui tametsi.","styles":{}}],"children":[]},{"id":"avgoyfos69bvat094q3skvku","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Censura volutabrum cogito magni. Ait tenus labore corrigo quasi abstergo omnis statua accendo veniam. Vulariter repellat defendo suadeo defessus.\\nUtique turba demitto tamisium tenus laboriosam tandem depopulo assentator. Soleo harum aduro cohors. Utrimque animadverto quae supplanto careo.","styles":{}}],"children":[]}]",
