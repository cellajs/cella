    "tags": [
      {
        "count": 0,
        "description": "AI capability layer: a server-side tool registry and a Model Context Protocol (MCP) endpoint that exposes that registry to external MCP clients. Ships no LLM transport or agent of its own — forks build AI features and agent products (e.g. chat) on top, reusing the same tool registry.",
        "kind": "module",
        "name": "ai",
      },
      {
        "count": 6,
        "description": "Endpoints for managing file based *attachments* (e.g. images, PDFs, documents) linked to
    entities such as organizations or users. Files are uploaded directly by the client; the API handles
    metadata registration, linking, access, and preview utilities.",
        "kind": "module",
        "name": "attachments",
      },
      {
        "count": 23,
        "description": "*Authentication* endpoints supporting multiple sign-in methods, including OAuth
    (Google, Microsoft, GitHub), and passkeys (WebAuthn). These routes cover user sign-up, sign-in,
    email verification, account linking, and impersonation for system admins.",
        "kind": "module",
        "name": "auth",
      },
      {
        "count": 5,
        "description": "Endpoints that operate across multiple *entity types*, such as \`users\` and \`organizations\`.
    *Entities* are identifiable domain objects that may be contextual, hierarchical (with parent/child
    relations), or actor-like. These endpoints offer shared logic across modules, including slug validation
    and entity visibility.",
        "kind": "module",
        "name": "entities",
      },
      {
        "count": 11,
        "description": "Endpoints related to the *current user*, meaning the user associated with the active session making
    the request. These routes are distinct from general \`users\` endpoints: while \`users\` may operate on
    any user in the system, \`me\` endpoints are scoped exclusively to the *current user* and follow a
    different authorization flow.",
        "kind": "module",
        "name": "me",
      },
      {
        "count": 6,
        "description": "Endpoints for managing *memberships*, which represent one-to-one relationships between a
    \`user\` and a contextual \`entity\` (e.g., an \`organization\`). Each membership includes role information
    and status flags such as \`archived\` or \`muted\`. Memberships can also reference parent entities,
    enabling hierarchical context.",
        "kind": "module",
        "name": "memberships",
      },
      {
        "count": 1,
        "description": "Endpoints for retrieving high-level counts for entities such as \`users\` and \`organizations\`.",
        "kind": "module",
        "name": "metrics",
      },
      {
        "count": 5,
        "description": "Endpoints for managing \`organizations\`, which are core context entities. Organizations are
    the highest ancestor in the parent hierarchy. They define access boundaries and are often the minimal
    primary scope for permission and resource management.",
        "kind": "module",
        "name": "organizations",
      },
      {
        "count": 5,
        "description": "Endpoints for managing *pages*, which are product entities supporting realtime sync and offline
    capabilities. Pages can be organized hierarchically and are used in /docs.",
        "kind": "module",
        "name": "pages",
      },
      {
        "count": 3,
        "description": "Endpoints for handling incoming *requests* such as contact form submissions, newsletter signups,
    and waitlist entries.",
        "kind": "module",
        "name": "requests",
      },
      {
        "count": 2,
        "description": "Endpoints for tracking entity view counts and marking entities as seen by the current user.",
        "kind": "module",
        "name": "seen",
      },
      {
        "count": 4,
        "description": "*System level* endpoints for administrative actions and platform wide functionality. These endpoints
    support operations such as user invitations, file uploads, and webhook handling.",
        "kind": "module",
        "name": "system",
      },
      {
        "count": 9,
        "description": "System-level endpoints for managing *tenants*. Tenants are top-level isolation boundaries used by
    Row-Level Security (RLS) to partition data. Only system administrators can manage tenants.",
        "kind": "module",
        "name": "tenants",
      },
      {
        "count": 2,
        "description": "Endpoints for managing *users* at the system level. Unlike context entities (such as
    \`organizations\`), a \`user\` is a "global" entity and not scoped to a specific context. These endpoints
    are intended for administrative operations on any user in the system.",
        "kind": "module",
        "name": "users",
      },
      {
        "count": 2,
        "description": "Endpoints for Yjs collaborative editing support. Provides auth tokens for the Yjs relay worker and
    accepts client-computed derived fields from collaborative editing sessions.",
        "kind": "module",
        "name": "yjs",
      },
    ],
  },
}
`;
