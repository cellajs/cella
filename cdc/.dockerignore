# Ignore everything by default
*

# Include necessary files for build context

# Root config files
!package.json
!pnpm-lock.yaml
!pnpm-workspace.yaml

# CDC Worker
!cdc/package.json
!cdc/src/
!cdc/tsconfig.json

# Backend source (for bundled imports via tsup)
!backend/src/

# Shared package
!shared/

# Patches
!patches/

# Ignore tests and dev files
**/*.test.ts
**/*.spec.ts
**/tests/
**/.env*
**/node_modules/
**/.git/
**/dist/
**/*.md
**/.DS_Store
