{
  "name": "@cella/cdc",
  "version": "0.0.2",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "start": "node dist/cdc-worker.js",
    "start:dev": "tsx src/cdc-worker.ts",
    "dev": "cross-env NODE_ENV=development tsx ../shared/scripts/wait-backend.ts -i 2000 -t 60000 && tsx watch --env-file=../backend/.env src/cdc-worker.ts",
    "build": "cross-env NODE_ENV=production tsup",
    "ts": "cd .. && tsgo -p cdc/tsconfig.json --pretty",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dotenv-run/core": "^1.3.8",
    "@hono/node-server": "^1.19.11",
    "drizzle-orm": "1.0.0-beta.15-859cf75",
    "hono": "^4.12.5",
    "pg-logical-replication": "^2.3.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "shared": "workspace:*",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "24.10.13",
    "@types/ws": "^8.18.1",
    "cross-env": "^10.1.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.4"
  }
}
